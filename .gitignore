# Compiled binaries — Makefile builds to ./bin.
# NOTE: bare names like "agentmon-agent" would ALSO ignore the source dirs
# agent/cmd/agentmon-agent/ and hubd/cmd/agentmon-hubd/, so ignore the output
# dir, not the binary names.
/bin/
/spike-0.5/spike
/spike-0.5/smoke
*.test
*.out

# Secrets / runtime artifacts (never commit)
cert.pem
key.pem
token.txt
*.sqlite
*.db
/data/

# Spike scratch (throwaway Claude working dir)
/spike-0.5/scratch/

# Node / web build output
node_modules/
web/dist/

# Logs
*.log

# Built SPA copied into the embed dir; keep only the placeholder index.html tracked
/hubd/internal/webui/dist/*
!/hubd/internal/webui/dist/index.html
