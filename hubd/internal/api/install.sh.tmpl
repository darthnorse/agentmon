#!/usr/bin/env bash
# shellcheck shell=bash
# AgentMon agent installer — served by the hub, templated with its own URL + checksums.
# Re-running on a host that's already installed UPDATES the binary in place (keeps the
# enrollment + config); a first run enrolls + installs the systemd unit. With Claude
# Code or Codex present it offers to install state hooks.
# Usage: sudo bash -c "$(curl -fsSL <hub>/install.sh)" [-- --hostname=H --user=U --socket=S --hooks[=claude|codex|all]|--no-hooks --dry-run]
#   The bash -c "$(curl ...)" form keeps the script's stdin on your terminal, so the hooks Y/n prompt can
#   read your answer. `curl ... | sudo bash` also works but can't prompt (stdin is the pipe + sudo's pty),
#   so it falls back to telling you which explicit --hooks mode to use.
# --socket defaults to a dedicated 'agentmon' socket (the agent never sees your default
# socket); use --socket=default for the standard socket, or --socket=<name> for another.
set -euo pipefail

HUB_URL="{{.HubURL}}"
SHA256_AMD64="{{.SHA256AMD64}}"
SHA256_ARM64="{{.SHA256ARM64}}"
AGENT_PORT="8377"

HOSTNAME_OVERRIDE=""
USER_OVERRIDE=""
SOCKET_OVERRIDE=""
DRY_RUN="0"
HOOKS_MODE="auto" # auto-detect + prompt; claude; codex; all; or none
for arg in "$@"; do
  case "$arg" in
    --hostname=*) HOSTNAME_OVERRIDE="${arg#*=}" ;;
    --user=*)     USER_OVERRIDE="${arg#*=}" ;;
    --socket=*)   SOCKET_OVERRIDE="${arg#*=}" ;;
    --hooks)      HOOKS_MODE="claude" ;; # backward-compatible legacy meaning
    --hooks=claude) HOOKS_MODE="claude" ;;
    --hooks=codex)  HOOKS_MODE="codex" ;;
    --hooks=all)    HOOKS_MODE="all" ;;
    --hooks=*)    echo "unknown hooks mode: ${arg#*=} (want claude, codex, or all)" >&2; exit 2 ;;
    --no-hooks)   HOOKS_MODE="none" ;;
    --dry-run)    DRY_RUN="1" ;;
    *) echo "unknown argument: $arg" >&2; exit 2 ;;
  esac
done

die() { echo "error: $*" >&2; exit 1; }

# download_and_verify fetches the agent binary for $ARCH into $TMP and checks its
# sha256 against the templated expectation before anything is installed.
download_and_verify() {
  TMP="$(mktemp)"
  trap 'rm -f "$TMP"' EXIT
  echo "Downloading agent ($ARCH)..."
  curl -fsSL "$HUB_URL/dl/agent-linux-$ARCH" -o "$TMP"
  local got
  got="$(sha256sum "$TMP" | cut -d' ' -f1)"
  [ "$got" = "$SHA256_EXPECT" ] || die "checksum mismatch (got $got, want $SHA256_EXPECT)"
}

# smoke_test polls the agent's loopback health endpoint until it answers.
smoke_test() {
  echo "Smoke-testing the agent..."
  local ok="0"
  for _ in 1 2 3 4 5; do
    if curl -fsS "http://127.0.0.1:$AGENT_PORT/healthz" >/dev/null 2>&1; then ok="1"; break; fi
    sleep 1
  done
  [ "$ok" = "1" ] || die "agent did not become healthy; check: journalctl -u agentmon-agent"
}

# provision_hook_token gives the agent a hook auth token: generate one, materialise it
# at a 0600 path the hook command can read, wire BOTH hook_token + hook_token_file into
# agent.toml as top-level keys (BEFORE the [[targets]] table, swapped in ATOMICALLY so an
# interruption can't truncate the live config), and restart so the agent loads it.
# Idempotency keys on hook_token_file — we always write the pair, so its presence means
# our provisioning is done.
provision_hook_token() {
  hook_token_ready && return 0
  # A hook_token without our companion hook_token_file is an operator's manual config;
  # don't duplicate the key or risk the literal token landing in settings.json.
  if grep -q '^hook_token' /etc/agentmon/agent.toml 2>/dev/null; then
    die "agent.toml sets hook_token without hook_token_file; add hook_token_file, then run 'agentmon-agent hooks install' manually"
  fi
  local tok
  tok="$( { tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 40; } 2>/dev/null || true )"
  [ -n "$tok" ] || die "could not generate a hook token"
  umask 077
  printf '%s' "$tok" > /etc/agentmon/hook_token
  chown "$RUN_USER" /etc/agentmon/hook_token
  chmod 600 /etc/agentmon/hook_token
  awk '/^\[\[targets\]\]/ && !ins { print "hook_token = \"file:/etc/agentmon/hook_token\""; print "hook_token_file = \"/etc/agentmon/hook_token\""; ins=1 } { print }' \
    /etc/agentmon/agent.toml > /etc/agentmon/agent.toml.new
  if ! grep -q '^hook_token_file' /etc/agentmon/agent.toml.new; then
    rm -f /etc/agentmon/agent.toml.new
    die "could not wire hook_token into agent.toml (no top-level [[targets]] anchor)"
  fi
  chown "$RUN_USER" /etc/agentmon/agent.toml.new
  chmod 600 /etc/agentmon/agent.toml.new
  mv -f /etc/agentmon/agent.toml.new /etc/agentmon/agent.toml # atomic
  systemctl restart agentmon-agent
  smoke_test
}

# BEGIN hook setup functions (kept delimited for focused shell regression tests).
provider_settings_path() {
  local home_dir="$1" provider="$2"
  case "$provider" in
    claude) echo "$home_dir/.claude/settings.json" ;;
    codex)  echo "$home_dir/.codex/hooks.json" ;;
    *) return 1 ;;
  esac
}

hook_token_ready() {
  grep -q '^hook_token_file' /etc/agentmon/agent.toml 2>/dev/null
}

# install_hooks_into merges AgentMon's state hooks into the selected provider's
# global JSON config, running per-user file operations AS RUN_USER (via runuser)
# so root never follows a symlink the run-user controls. Idempotent — Merge de-dupes.
install_hooks_into() {
  local home_dir="$1" provider="$2" config_dir settings restart_note
  settings="$(provider_settings_path "$home_dir" "$provider")" || die "unsupported hook provider: $provider"
  config_dir="${settings%/*}"
  case "$provider" in
    claude)
      restart_note="restart active Claude Code sessions to pick them up" ;;
    codex)
      restart_note="restart active Codex sessions and approve the hook trust prompt if shown" ;;
  esac
  command -v runuser >/dev/null 2>&1 || die "runuser (util-linux) is required to install hooks safely"
  runuser -u "$RUN_USER" -- mkdir -p "$config_dir"
  runuser -u "$RUN_USER" -- /usr/local/bin/agentmon-agent hooks install --provider "$provider" --config /etc/agentmon/agent.toml --settings "$settings"
  echo "✓ AgentMon $provider hooks installed into $settings — $restart_note."
}

# provider_detected checks the run user's config directory and PATH. Running the
# command lookup as RUN_USER avoids mistaking root's PATH for the monitored user's.
provider_detected() {
  local home_dir="$1" provider="$2"
  [ -d "$home_dir/.$provider" ] && return 0
  command -v runuser >/dev/null 2>&1 || return 1
  runuser -u "$RUN_USER" -- sh -lc "command -v $provider" </dev/null >/dev/null 2>&1
}

provider_has_hooks() {
  local home_dir="$1" provider="$2" settings
  settings="$(provider_settings_path "$home_dir" "$provider")" || return 1
  grep -q 'agentmon-hook' "$settings" 2>/dev/null
}

# Runner CLI + skills: the `agentmon` symlink gives runner sessions the
# report/doctor/import-epics CLI; install-skills writes the binary-embedded
# epic-pipeline / plan-epics prompts into the run user's provider dirs.
# Idempotent; runs on update too — that is how skill edits reach the fleet.
install_runner_files() {
  ln -sfn /usr/local/bin/agentmon-agent /usr/local/bin/agentmon
  local home_dir
  home_dir="$(getent passwd "$RUN_USER" | cut -d: -f6)"
  [ -n "$home_dir" ] || home_dir="${HOME:-/root}"
  if runuser -u "$RUN_USER" -- /usr/local/bin/agentmon-agent install-skills --home "$home_dir" >/dev/null; then
    echo "✓ runner skills installed for '$RUN_USER' (epic-pipeline, plan-epics)."
  else
    echo "warning: runner skill install failed — re-run: runuser -u $RUN_USER -- agentmon-agent install-skills" >&2
  fi
}

# maybe_install_hooks selects explicit providers or auto-detects Claude Code and
# Codex. Auto mode offers every detected provider that is not already configured,
# prompts once, provisions one shared token, then performs idempotent per-user merges.
maybe_install_hooks() {
  [ "$HOOKS_MODE" = "none" ] && return 0
  local home_dir install_claude="0" install_codex="0" token_ready="0" label rerun
  home_dir="$(getent passwd "$RUN_USER" 2>/dev/null | cut -d: -f6)"
  [ -n "$home_dir" ] || home_dir="${HOME:-/root}"
  hook_token_ready && token_ready="1"

  case "$HOOKS_MODE" in
    claude) install_claude="1" ;;
    codex) install_codex="1" ;;
    all) install_claude="1"; install_codex="1" ;;
    auto)
      if provider_detected "$home_dir" claude && { [ "$token_ready" != "1" ] || ! provider_has_hooks "$home_dir" claude; }; then
        install_claude="1"
      fi
      if provider_detected "$home_dir" codex && { [ "$token_ready" != "1" ] || ! provider_has_hooks "$home_dir" codex; }; then
        install_codex="1"
      fi
      [ "$install_claude" = "1" ] || [ "$install_codex" = "1" ] || return 0
      case "${install_claude}${install_codex}" in
        10) label="Claude Code"; rerun="--hooks=claude" ;;
        01) label="Codex"; rerun="--hooks=codex" ;;
        11) label="Claude Code and Codex"; rerun="--hooks=all" ;;
      esac
      # A reliable prompt needs OUR stdin to be the terminal. Under `curl | sudo bash`,
      # stdin is the pipe — and sudo's pty is fed by that pipe, not the keyboard — so a
      # /dev/tty prompt reads EOF (skips) while the keystroke leaks to the parent shell.
      # Detect a non-interactive stdin and point at the explicit flag instead.
      if [ ! -t 0 ] || [ ! -r /dev/tty ]; then
        echo "$label detected — re-run with $rerun to install live-state hooks (or --no-hooks to skip)."
        return 0
      fi
      printf '%s detected. Install AgentMon hooks for live agent state? [y/N] ' "$label" > /dev/tty
      local ans=""
      read -r -t 30 ans < /dev/tty || true
      case "$ans" in
        [Yy]*) ;;
        *) echo "Skipping hooks (re-run with $rerun to enable)."; return 0 ;;
      esac
      ;;
    *) die "unsupported hooks mode: $HOOKS_MODE" ;;
  esac

  provision_hook_token
  if [ "$install_claude" = "1" ]; then
    install_hooks_into "$home_dir" claude
  fi
  if [ "$install_codex" = "1" ]; then
    install_hooks_into "$home_dir" codex
  fi
  return 0
}
# END hook setup functions.

command -v systemctl >/dev/null 2>&1 || die "systemd (systemctl) is required; this installer does not support non-systemd hosts"
command -v curl >/dev/null 2>&1 || die "curl is required"

ARCH_RAW="$(uname -m)"
case "$ARCH_RAW" in
  x86_64|amd64) ARCH="amd64"; SHA256_EXPECT="$SHA256_AMD64" ;;
  aarch64|arm64) ARCH="arm64"; SHA256_EXPECT="$SHA256_ARM64" ;;
  *) die "unsupported architecture: $ARCH_RAW (only amd64/arm64)" ;;
esac

HOST="${HOSTNAME_OVERRIDE:-$(hostname -s)}"
RUN_USER="${USER_OVERRIDE:-${SUDO_USER:-$(id -un)}}"
# Default to a DEDICATED tmux socket ('agentmon') so the agent never watches the
# run-user's default socket (where unrelated/sensitive sessions live) unless asked.
# --socket=default selects the standard default socket; --socket=<name> any other.
SOCKET="${SOCKET_OVERRIDE:-agentmon}"

# A prior install is recognised by its config + secret files; re-running then just
# updates the binary (no re-enroll → no 409). To force a clean re-enroll instead,
# remove /etc/agentmon first.
INSTALLED="0"
if [ -f /etc/agentmon/agent.toml ] && [ -f /etc/agentmon/hub_token ] && [ -f /etc/agentmon/signing_key ]; then
  INSTALLED="1"
fi

hooks_plan() {
  case "$HOOKS_MODE" in
    claude) echo "install Claude Code hooks" ;;
    codex)  echo "install Codex hooks" ;;
    all)    echo "install Claude Code + Codex hooks" ;;
    none)   echo "skip (--no-hooks)" ;;
    *)      echo "auto (detect Claude Code/Codex + prompt)" ;;
  esac
}

echo "AgentMon installer:"
echo "  hub:      $HUB_URL"
echo "  hostname: $HOST"
echo "  run-as:   $RUN_USER"
echo "  arch:     $ARCH"
echo "  socket:   ${SOCKET:-<default>} (tmux -L $SOCKET)"
echo "  hooks:    $(hooks_plan)"
if [ "$INSTALLED" = "1" ]; then
  echo "  mode:     update (existing install — binary swap, config preserved)"
else
  echo "  mode:     fresh install (enroll + systemd unit)"
fi

if [ "$DRY_RUN" = "1" ]; then
  if [ "$INSTALLED" = "1" ]; then
    echo "[dry-run] would update the binary from $HUB_URL/dl/agent-linux-$ARCH (sha256 $SHA256_EXPECT) and restart the service; enrollment + config preserved."
  else
    echo "[dry-run] would download $HUB_URL/dl/agent-linux-$ARCH (sha256 $SHA256_EXPECT)"
    echo "[dry-run] would enroll at $HUB_URL/api/v1/enroll as '$HOST'"
    echo "[dry-run] would write /etc/agentmon/agent.toml + secrets, install + start the systemd unit"
  fi
  echo "[dry-run] would install the /usr/local/bin/agentmon symlink + runner skills for '$RUN_USER'"
  case "$HOOKS_MODE" in
    claude) echo "[dry-run] would provision a hook token + install Claude Code hooks for '$RUN_USER'" ;;
    codex)  echo "[dry-run] would provision a hook token + install Codex hooks for '$RUN_USER'" ;;
    all)    echo "[dry-run] would provision one hook token + install Claude Code and Codex hooks for '$RUN_USER'" ;;
    none)   echo "[dry-run] would NOT install hooks" ;;
    *)      echo "[dry-run] would detect Claude Code and Codex, then offer to install hooks for detected clients" ;;
  esac
  echo "[dry-run] no changes made."
  exit 0
fi

[ "$(id -u)" = "0" ] || die "must run as root (use sudo)"

# The agentmon tmux server runs INSIDE the agent service's cgroup (the agent, or a
# session created via POST /sessions, starts it). Under the default
# KillMode=control-group, a `systemctl stop`/`restart` — including this installer's
# binary swap below — kills the WHOLE cgroup: the tmux server AND every monitored
# session. Install a KillMode=process drop-in and reload it BEFORE any (re)start so
# even an existing control-group host is protected on this very run (and forever after).
ensure_killmode() {
  install -d -m 0755 /etc/systemd/system/agentmon-agent.service.d
  cat > /etc/systemd/system/agentmon-agent.service.d/killmode.conf <<'KMEOF'
[Service]
KillMode=process
KMEOF
  systemctl daemon-reload 2>/dev/null || true
}
ensure_killmode

# ── Update path: existing install → swap the binary in place, keep everything else.
if [ "$INSTALLED" = "1" ]; then
  if [ -x /usr/local/bin/agentmon-agent ] && \
     [ "$(sha256sum /usr/local/bin/agentmon-agent | cut -d' ' -f1)" = "$SHA256_EXPECT" ]; then
    # Binary is current. Re-running the installer is also the documented heal path,
    # so if the service is stopped/crashed, restart it rather than no-op'ing.
    if systemctl is-active --quiet agentmon-agent; then
      echo "✓ $HOST already up to date (sha256 $SHA256_EXPECT) and running."
    else
      echo "Binary is current but the agent is not running — restarting..."
      systemctl restart agentmon-agent
      smoke_test
      echo "✓ $HOST restarted."
    fi
  else
    echo "Updating the agent binary in place (enrollment + config preserved)..."
    download_and_verify
    install -m 0755 "$TMP" /usr/local/bin/agentmon-agent
    systemctl restart agentmon-agent
    smoke_test
    echo "✓ $HOST updated and restarted."
  fi
  install_runner_files
  maybe_install_hooks # re-run with --hooks to add hooks to an existing agent
  exit 0
fi

# ── Fresh install: enroll, write config + secrets + systemd unit, enable.
download_and_verify
install -m 0755 "$TMP" /usr/local/bin/agentmon-agent

echo "Enrolling..."
REQ="$(printf '{"hostname":"%s","os":"linux","arch":"%s","agentVersion":"installed","target":{"osUser":"%s","socket":"%s","label":"default"}}' "$HOST" "$ARCH" "$RUN_USER" "$SOCKET")"
RESP="$(curl -fsS -X POST -H 'Content-Type: application/json' -d "$REQ" "$HUB_URL/api/v1/enroll")" || die "enroll request failed"

# `|| true` keeps a missing field (or a SIGPIPE from grep|head under pipefail)
# from aborting via set -e before the explicit guard below can report it.
extract() { printf '%s' "$RESP" | grep -o "\"$1\":\"[^\"]*\"" | head -n1 | cut -d'"' -f4; }
SERVER_ID="$(extract serverId || true)"
BEARER="$(extract bearer || true)"
SIGNING_KEY="$(extract signingKey || true)"
if [ -z "$SERVER_ID" ] || [ -z "$BEARER" ] || [ -z "$SIGNING_KEY" ]; then
  die "enroll response missing fields: $RESP"
fi

install -d -m 0755 /etc/agentmon
umask 077
printf '%s' "$BEARER" > /etc/agentmon/hub_token
printf '%s' "$SIGNING_KEY" > /etc/agentmon/signing_key
cat > /etc/agentmon/agent.toml <<EOF
listen = "0.0.0.0:$AGENT_PORT"
server_id = "$SERVER_ID"
hub_token = "file:/etc/agentmon/hub_token"
directive_key = "file:/etc/agentmon/signing_key"
scrollback_lines = 5000
[[targets]]
  os_user = "$RUN_USER"
  socket_name = "$SOCKET"
  label = "default"
EOF
chown "$RUN_USER" /etc/agentmon/agent.toml /etc/agentmon/hub_token /etc/agentmon/signing_key
chmod 600 /etc/agentmon/agent.toml /etc/agentmon/hub_token /etc/agentmon/signing_key

cat > /etc/systemd/system/agentmon-agent.service <<EOF
[Unit]
Description=AgentMon agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=$RUN_USER
ExecStart=/usr/local/bin/agentmon-agent --config /etc/agentmon/agent.toml
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable --now agentmon-agent

smoke_test
install_runner_files
maybe_install_hooks

echo "✓ $HOST enrolled — pending approval. Approve it in the AgentMon web UI (or 'agentmon-hubd server approve $HOST' on the hub)."
if [ -z "$SOCKET_OVERRIDE" ]; then
  echo "  note: the agent watches the dedicated '$SOCKET' socket — run monitored sessions with 'tmux -L $SOCKET ...'"
  echo "        (to watch your standard default socket instead, reinstall with --socket=default)"
fi
